---
layout: base.njk
title: Home
---

<div class="home">
  <h1>Sandip Chintawar</h1>
  <p class="tagline">Thoughts on building, living well, and the things I'm learning along the way.</p>

  <ul class="post-list">
    {%- for post in collections.posts %}
    <li>
      <a href="{{ post.url }}">{{ post.data.title }}</a>
      <time datetime="{{ post.data.date | date('yyyy-MM-dd') }}">{{ post.data.date | date("MMMM d, yyyy") }}</time>
    </li>
    {%- endfor %}
  </ul>
</div>
