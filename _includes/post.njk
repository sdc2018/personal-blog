---
layout: base.njk
---

<article class="post">
  <h1>{{ title }}</h1>
  <time datetime="{{ date | date('yyyy-MM-dd') }}">{{ date | date("MMMM d, yyyy") }}</time>
  {% if subtitle %}<p class="subtitle">{{ subtitle }}</p>{% endif %}

  <div class="post-content">
    {{ content | safe }}
  </div>

  <a href="/" class="back-link">&larr; All posts</a>
</article>
